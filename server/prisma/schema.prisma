generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  REWORK_REQUIRED
  APPROVED
  LOCKED
}

enum UomType {
  NUMBER
  PERCENTAGE
  CURRENCY
  BOOLEAN
  TEXT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  department   String
  title        String
  isActive     Boolean  @default(true)
  managerId    String?
  manager      User?    @relation("ManagerReports", fields: [managerId], references: [id], onDelete: SetNull)
  reports      User[]   @relation("ManagerReports")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  goals        Goal[]   @relation("EmployeeGoals")
  reviewedGoals Goal[]  @relation("ReviewedGoals")
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String
  thrustArea  String
  uomType     UomType
  target      String
  weightage   Int
  deadline    DateTime
  status      GoalStatus @default(DRAFT)
  managerNote String?
  reviewedAt  DateTime?
  lockedAt    DateTime?
  employeeId  String
  employee    User       @relation("EmployeeGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?     @relation("ReviewedGoals", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId, status])
  @@index([reviewedById])
}
