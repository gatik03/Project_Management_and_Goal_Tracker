generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum GoalStatus {
  DRAFT
  SUBMITTED
}

enum UomType {
  NUMBER
  PERCENTAGE
  CURRENCY
  BOOLEAN
  TEXT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  department   String
  title        String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  goals        Goal[]
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String
  thrustArea  String
  uomType     UomType
  target      String
  weightage   Int
  deadline    DateTime
  status      GoalStatus @default(DRAFT)
  employeeId  String
  employee    User       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId, status])
}
